# Copy to .env for local development (never commit .env)

# Django — lokalno
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Site
SITE_BASE_URL=http://localhost:8000
CONTACT_PHONE=+381 62 810 7037
CONTACT_PHONE_DISPLAY=+381 62 810 7037
CONTACT_PHONE_2=+381 61 146 3318
CONTACT_PHONE_2_DISPLAY=+381 61 146 3318
CONTACT_ADDRESS=Naše usluge pružamo na teritoriji cele Srbije.

# SEO (optional)
# SEO_DEFAULT_TITLE=
# SEO_DEFAULT_DESCRIPTION=
# SEO_DEFAULT_OG_IMAGE_URL=https://your-domain.com/static/img/og-default.jpg
# SEO_BLOG_AUTHOR_TYPE=Organization
# SEO_PERSON_NAME=
# SEO_PERSON_URL=
# SEO_PERSON_IMAGE=
# SEO_PERSON_JOB_TITLE=
# SEO_DISALLOW_ALL=False
# SEO_CANONICAL_LANGUAGE_PREFIX=False
# SEO_HREFLANG_ENABLED=False

# Optional: override SQLite path (local only)
# DATABASE_URL=sqlite:///db.sqlite3

# ---------------------------------------------------------------------------
# Production (Render) — DJANGO_SETTINGS_MODULE=config.settings.production
# ---------------------------------------------------------------------------
# DEBUG=False
# ALLOWED_HOSTS=your-app.onrender.com,yourdomain.com
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# DB_SSLMODE=require
# SECURE_SSL_REDIRECT=True
# USE_X_FORWARDED_HOST=True
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://your-app.onrender.com

# Cloudflare R2 media (production / Render)
# USE_R2_STORAGE=True
# REQUIRE_R2_CONFIG=True
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=cementnekosuljiceivkov
# R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_REGION_NAME=auto
# R2_CUSTOM_DOMAIN=media.yourdomain.com
# R2_MEDIA_URL=https://media.yourdomain.com/
# CSP_EXTRA_MEDIA_ORIGINS=https://media.yourdomain.com
#
# Legacy aliases (still supported): AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, …

# Cloudflare orange-cloud proxy (optional)
# USE_CLOUDFLARE_PROXY=True
# PUBLIC_HTML_CACHE_MAX_AGE=300
# PUBLIC_HTML_S_MAXAGE=600
